@model Club
@{
    ViewData["Title"] = "Delete Club";
}

<h2 class="mt-3">Delete Club</h2>

<div class="alert alert-warning mt-3" style="max-width:500px;">
    <p>Are you sure you want to delete <strong>@Model.Name</strong>?</p>
    <p class="text-muted mb-0">Location: @Model.Location</p>
</div>

<form asp-action="Delete" method="post">
    @* Pass just the fields the controller needs to delete and display in TempData *@
    <input type="hidden" asp-for="ClubID" />
    <input type="hidden" asp-for="Name" />

    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="List" class="btn btn-secondary ms-2">Cancel</a>
</form>
