@model List<Club>
@{
    ViewData["Title"] = "Clubs";
}

<h2 class="mt-3">Clubs</h2>

<a asp-action="AddEdit" class="btn btn-primary mb-3">Add Club</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Location</th>
            <th>Description</th>
            <th></th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var club in Model)
        {
            <tr>
                <td>@club.Name</td>
                <td>@club.Location</td>
                <td>@club.Description</td>
                <td>
                    <a asp-action="AddEdit" asp-route-id="@club.ClubID"
                       class="btn btn-sm btn-outline-secondary">Edit</a>
                </td>
                <td>
                    <a asp-action="Delete" asp-route-id="@club.ClubID"
                       class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
