@model PicklrProgram
@{
    ViewData["Title"] = ViewBag.Action + " Program";
    var clubs = ViewBag.Clubs as List<Club> ?? new List<Club>();
    var selectedDays = (Model.AvailableDays ?? string.Empty)
        .Split(',', StringSplitOptions.RemoveEmptyEntries).ToHashSet();
    string[] weekdays = { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
}

<h2 class="mt-3">@ViewBag.Action Program</h2>

<form asp-action="AddEdit" method="post" class="mt-3" style="max-width:600px;">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <input type="hidden" asp-for="ProgramID" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>

    <div class="mb-3">
        <label asp-for="ClubID" class="form-label">Club</label>
        <select asp-for="ClubID" class="form-select">
            <option value="">-- Select a club --</option>
            @foreach (var club in clubs)
            {
                <option value="@club.ClubID" selected="@(club.ClubID == Model.ClubID)">@club.Name</option>
            }
        </select>
        <span asp-validation-for="ClubID" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Available Days</label>
        <div>
            @foreach (var day in weekdays)
            {
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox" name="days" value="@day" id="day_@day" checked="@selectedDays.Contains(day)" />
                    <label class="form-check-label" for="day_@day">@day</label>
                </div>
            }
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Fee" class="form-label"></label>
        <div class="input-group">
            <span class="input-group-text">$</span>
            <input asp-for="Fee" class="form-control" />
        </div>
        <span asp-validation-for="Fee" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">@ViewBag.Action</button>
    <a asp-action="List" class="btn btn-secondary ms-2">Cancel</a>
</form>

@section scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
}
