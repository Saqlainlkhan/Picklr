@model PicklProgram
@{
    ViewData["Title"] = "Delete Program";
}

<h2 class="mt-3">Delete Program</h2>

<div class="alert alert-warning mt-3" style="max-width:500px;">
    <p>Are you sure you want to delete <strong>@Model.Name</strong>?</p>
    <p class="text-muted mb-0">Fee: @Model.Fee.ToString("C")</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ProgramID" />
    <input type="hidden" asp-for="Name" />

    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="List" class="btn btn-secondary ms-2">Cancel</a>
</form>
