@model AppUser
@{
    ViewData["Title"] = "Delete User";
}

<h2 class="mt-3">Delete User</h2>

<div class="alert alert-warning mt-3" style="max-width:500px;">
    <p>Are you sure you want to delete <strong>@Model.FullName</strong>?</p>
    <p class="text-muted mb-0">Email: @Model.Email &mdash; Role: @Model.Role</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="UserID" />
    <input type="hidden" asp-for="FirstName" />
    <input type="hidden" asp-for="LastName" />

    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="List" class="btn btn-secondary ms-2">Cancel</a>
</form>
