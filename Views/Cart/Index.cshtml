@model List<CartItem>
@{
    ViewData["Title"] = "Cart";
}

<h2 class="mt-3">My Cart</h2>

@if (!Model.Any())
{
    <p>Your cart is empty.</p>
    <a asp-controller="Home" asp-action="Program" class="btn btn-primary">Continue Browsing</a>
}
else
{
    <table class="table table-bordered table-striped" style="max-width:800px;">
        <thead class="table-dark">
            <tr>
                <th>Program</th>
                <th>Club</th>
                <th>Date</th>
                <th>Fee</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProgramName</td>
                    <td>@item.ClubName</td>
                    <td>@(DateTime.TryParse(item.SelectedDate, out var d) ? d.ToString("MM/dd/yyyy") : item.SelectedDate)</td>
                    <td>@item.Fee.ToString("C")</td>
                    <td>
                        <form asp-action="Remove" method="post">
                            <input type="hidden" name="id" value="@item.CartItemId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="3" class="text-end">Total</th>
                <th colspan="2">@Model.Sum(i => i.Fee).ToString("C")</th>
            </tr>
        </tfoot>
    </table>

    <form asp-action="PayAndConfirm" method="post" class="d-inline">
        <button type="submit" class="btn btn-success">Pay &amp; Confirm</button>
    </form>
    <form asp-action="ClearAll" method="post" class="d-inline">
        <button type="submit" class="btn btn-outline-danger">Clear All</button>
    </form>
    <a asp-controller="Home" asp-action="Program" class="btn btn-secondary">Continue Browsing</a>
}
