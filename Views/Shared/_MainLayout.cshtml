@{
    Layout = "_Layout";

    // Used to highlight the active nav link
    string ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string act  = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}

<div class="container">
    <header>
        <nav class="navbar navbar-expand-md navbar-dark bg-success mt-2 rounded">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold"
                   asp-area="" asp-controller="Home" asp-action="Index">Picklr</a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    @* Left-side links *@
                    <div class="navbar-nav me-auto">
                        <a class="nav-item nav-link
                             @(ctrl == "Home" && act == "About" ? "active" : "")"
                           asp-area="" asp-controller="Home" asp-action="About">About</a>

                        <a class="nav-item nav-link
                             @(ctrl == "Home" && act == "Club" ? "active" : "")"
                           asp-area="" asp-controller="Home" asp-action="Club">Club</a>

                        <a class="nav-item nav-link
                             @(ctrl == "Home" && act == "Program" ? "active" : "")"
                           asp-area="" asp-controller="Home" asp-action="Program">Program</a>

                        <a class="nav-item nav-link
                             @(ctrl == "Home" && act == "Shop" ? "active" : "")"
                           asp-area="" asp-controller="Home" asp-action="Shop">Shop</a>
                    </div>

                    @* Right-side Admin link *@
                    <div class="navbar-nav ms-auto">
                        <a class="nav-item nav-link"
                           asp-area="Admin" asp-controller="Home" asp-action="Index">Admin</a>
                    </div>
                </div>
            </div>
        </nav>

        @* TempData confirmation message (placeholder for future client-side operations) *@
        @if (TempData.Keys.Contains("message"))
        {
            <div class="alert alert-success mt-2 text-center">@TempData["message"]</div>
        }
    </header>

    <main>
        @RenderBody()
        @RenderSection("scripts", required: false)
    </main>

    <footer class="mt-4 py-3 border-top text-center text-muted">
        <p>&copy; @DateTime.Now.Year Picklr &mdash; All rights reserved.</p>
    </footer>
</div>
